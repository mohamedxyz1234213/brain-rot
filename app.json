{
  "expo": {
    "name": "BrainRot Healer",
    "slug": "brain-rot-healer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "brainrot",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "bundleIdentifier": "com.brainrothealer.app",
      "info": {
        "NSCameraUsageDescription": "BrainRot Healer uses your camera briefly to remind you who is in control. Nothing is stored.",
        "NSMicrophoneUsageDescription": "BrainRot Healer records your personal promises to play back as accountability reminders."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0E0B04",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "permissions": [
        "PACKAGE_USAGE_STATS",
        "SYSTEM_ALERT_WINDOW",
        "FOREGROUND_SERVICE",
        "ACTIVITY_RECOGNITION",
        "ACCESS_FINE_LOCATION"
      ],
      "package": "com.brainrothealer.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0E0B04"
        }
      ],
      "expo-secure-store",
      "expo-apple-authentication"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
